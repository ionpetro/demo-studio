# Cursor SDK — https://cursor.com/dashboard/integrations
CURSOR_API_KEY=

# Kernel — https://www.onkernel.com (free tier is fine; recording uses CDP screencast)
KERNEL_API_KEY=

# Frontend (Vercel) — point at the Railway backend. Leave empty for local same-origin dev.
NEXT_PUBLIC_API_URL=

# Backend — public base URL of this service. Used for every link handed out to
# agents (MCP watchUrl/statusUrl) and for video links in SSE events. When unset,
# links fall back to the request's Host header — localhost for local MCP
# clients — and the MCP response flags them shareable: false.
PUBLIC_URL=

# Supabase — DATABASE_URL enables Postgres persistence; SUPABASE_URL +
# SUPABASE_SECRET_KEY enable video storage. With storage configured, finished
# MP4s are uploaded to a public "videos" bucket, so watch links keep working
# after the recording machine shuts down. Without it, videos are only served
# from the local disk of the machine that recorded them.
DATABASE_URL=
SUPABASE_URL=
SUPABASE_SECRET_KEY=

# Backend (Railway) — extra allowed browser origins for CORS (comma-separated).
# https://demo-studio-three.vercel.app and all *.vercel.app previews are allowed by default.
FRONTEND_URL=

# Optional — override writable data dir (defaults to ./data locally, /tmp on Vercel).
# DEMO_STUDIO_DATA_DIR=
